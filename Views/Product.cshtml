@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var productPic = Model.Value<MediaWithCrops>("productImage");
    var knapp = Model.Value<Umbraco.Cms.Core.Models.Link>("productURL");
}

<div class="max-w-5xl mx-auto py-12 px-8">
    <a href="@Model.Parent?.Url()" class="inline-flex items-center gap-2 text-gray-600 hover:text-gray-900 mb-8 transition-colors">
        ← Tillbaka till shop
    </a>

    <div class="flex flex-col md:flex-row gap-12 items-start">
        <div class="w-full md:w-1/2">
            @if (productPic != null)
            {
                <img src="@productPic.MediaUrl()" alt="@Model.Value("productName")" class="w-full rounded-2xl shadow-lg object-cover" />
            }
            else
            {
                <img src="https://placehold.co/600x600?text=Image+Coming+Soon" class="w-full rounded-2xl shadow-lg" />
            }
        </div>
        <div class="w-full md:w-1/2 flex flex-col gap-4">
            <span class="text-sm border border-gray-400 text-gray-600 px-3 py-1 rounded-full w-fit">
                @Model.Value("productCategory")
            </span>
            <h1 class="text-3xl font-bold">@Model.Value("productName")</h1>
            <p class="text-gray-600 leading-relaxed">@Model.Value("productDesc")</p>
            <p class="text-2xl font-bold">@Model.Value("productPrice")</p>

            <a href="@(knapp?.Url ?? "#")" class="mt-4 bg-gray-900 text-white px-6 py-3 rounded-lg hover:bg-gray-700 transition-colors text-center">
                @Model.Value("productBtnText")
            </a>
        </div>

    </div>
</div>