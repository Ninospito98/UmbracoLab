@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var bannerBild = Model.Value<MediaWithCrops>("bannerBild");
}
@{
    var blogg = Umbraco.ContentAtRoot().First().Children().FirstOrDefault(x => x.ContentType.Alias == "blogg");
    var antal = Model.Value<int>("antalNyheter");
    var artiklar = blogg?.Children().Take(antal);
}
@{
    var shop = Umbraco.ContentAtRoot().First().Children().FirstOrDefault(x => x.ContentType.Alias == "shop");
    var antalMerch = Model.Value<int>("antalMerch");
    var merchs = shop?.Children().Take(antalMerch);
}
<main class="flex flex-col justify-center items-center">
    <section class="text-center">
        <h1 class="font-bold text-3xl mb-3">@Model.Value("bannerRubrik")</h1>
        <p class="mb-3">@Model.Value("bannerUndertext")</p>
        @if (bannerBild != null)
        {
            <img src="@bannerBild.MediaUrl()" alt="Banner" class="mx-auto w-3/4" />
        }
        else
        {
            <img src="https://placehold.co/800x400?text=Bilder+Kommer+Snart" alt="Coming Soon" class="mx-auto w-3/4" />
        }
    </section>
    <section class="text-center my-12 max-w-2xl mx-auto">
        <h2 class="font-bold text-2xl mb-3">@Model.Value("omRubrik")</h2>
        <p class="text-gray-600 leading-relaxed">@Model.Value("omUndertext")</p>
    </section>
    @if (Model.Value<bool>("visaSenaste"))
    {
        <section class="my-12">
            <h2 class="text-3xl font-bold text-center mb-8">Senaste artiklarna</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mt-8 text-center">
                @foreach (var artikel in artiklar!)
                {
                    var bild = artikel.Value<MediaWithCrops>("blogPic");

                    <a href="@artikel.Url()" class="bg-white rounded-2xl shadow hover:shadow-lg transition-shadow overflow-hidden">
                        <img src="@bild?.Url()" class="mx-auto h-80 mb-4 rounded" />
                        <div class="p-4">
                            <p class="text-xs text-gray-400 mb-1">@artikel.Value("blogDate")</p>
                            <h3 class="font-bold text-lg mb-2">@artikel.Value("blogTitle")</h3>
                            <p class="text-gray-600 text-sm">@artikel.Value("blogText")</p>
                        </div>
                    </a>
                }
            </div>
            <div class="mx-auto flex justify-center items-center">
                <a href="@Model.Value("omBtnURL")" class="inline-block mt-6 bg-gray-900 text-white px-6 py-3 rounded-lg hover:bg-gray-700 transition-colors">
                    @Model.Value("omBtnText")
                </a>
            </div>

        </section>
    }

    @if (Model.Value<bool>("visaSenasteMerch"))
    {
        <section class="my-12">
            <h2 class="text-3xl font-bold text-center mb-8">Senaste Merchs</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mt-8 text-center">
                @foreach (var merch in merchs!)
                {
                    var productImage = merch.Value<MediaWithCrops>("productImage");

                    <a href="@merch.Url()" class="block border p-4 m-8 rounded hover:shadow-lg">
                        <p class="text-end">
                            <span class="text-end text-xs border border-gray-400 text-gray-600 px-2 py-1 rounded-full">
                                @merch.Value("productCategory")
                            </span>
                        </p>

                        @if (productImage != null)
                        {
                            <img src="@productImage?.MediaUrl()" alt="@merch.Value("productName")" class="mx-auto h-80 mb-4 rounded" />
                        }
                        else
                        {
                            <img src="https://placehold.co/800x400?text=Image+Coming+Soon" alt="Coming Soon" class="w-full mb-4 rounded" />
                        }
                        <h2 class="font-bold text-lg">@merch.Value("productName")</h2>

                        <p class="text-center text-gray-600 my-2">@merch.Value("productDesc")</p>
                        <p class="text-center border border-gray-400 rounded bg-green-500 inline-block p-1 w-20 mt-2">@merch.Value("productPrice")</p>
                        <span href="@merch.Url()" class="mt-4 block bg-gray-900 text-white px-6 py-2 rounded-lg hover:bg-gray-700 transition-colors w-full">
                            @merch.Value("productBtnText")
                        </span>
                    </a>
                }
            </div>
            <div class="mx-auto flex justify-center items-center">
                <a href="@Model.Value("merchBtnUrl")" class="inline-block mt-6 bg-gray-900 text-white px-6 py-3 rounded-lg hover:bg-gray-700 transition-colors">
                    @Model.Value("merchBtnText")
                </a>
            </div>
        </section>
    }
    
    @if (Model.Value<bool>("visaPrenumerera"))
    {
        <section class="bg-gray-100 rounded-2xl text-center py-16 px-8 my-12">
            <h2 class="font-bold text-3xl mb-3">@Model.Value("prenRubrik")</h2>
            <p class="text-gray-500 mb-8">@Model.Value("prenUndertext")</p>
            <div class="flex justify-center gap-2 max-w-md mx-auto">
                <input type="email"
                       placeholder="Din e-postadress"
                       class="flex-1 px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-gray-400" />
                <button type="submit"
                        class="bg-gray-900 text-white px-6 py-3 rounded-lg hover:bg-gray-700 transition-colors">
                    Prenumerera
                </button>
            </div>
        </section>
    }
</main>
